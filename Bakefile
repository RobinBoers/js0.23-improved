#!/bin/bash

SRC=src
DIST=dist

REMOTE=s11
DOMAIN=geheimesite.nl

build() {
  npx electron-packager . "js0.23" \
    --icon=$SRC/favicon.icns \
    --out=$DIST \
    --ignore=$DIST \
    --prune
}

clean() {
  rm -rf $DIST
}

deploy() {
  lift deploy
}

serve() {
  cd $SRC
  waiter --dev
}

run() {
  npx electron .
}